<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Jardo's voice is captured by the bundled Python core (a sidecar process),
       not the Tauri binary. macOS only feeds real audio to a process whose
       bundle carries the audio-input entitlement; without it PortAudio opens a
       stream that only ever returns silence. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- Supervision drives Terminal via Apple Events. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
  <!-- The sidecar and its dylibs are ad-hoc signed (different identity than the
       app); allow them to load under the hardened runtime. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The frozen core JIT-maps its own code pages; permit unsigned executable
       memory so it can run. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
</dict>
</plist>
