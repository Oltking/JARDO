# Secrets policy: secrets live in the OS keychain / SOPS, never in files (SECURITY.md).
# .env is ignored defensively but must not be used for credentials.
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Node / frontend
node_modules/
dist/
.vite/

# Rust / Tauri
target/

# OS / editor
.DS_Store
.idea/
.vscode/

# Local data
*.sqlite3
qdrant_storage/
postgres-data/

# Private source material — spec, notes, and the vendor doc harvest stay local (owner policy)
*.md
!README.md
!PACKAGING.md
docs/
evals/scores.json
.run/

# Frozen core staged into the Tauri bundle (built by scripts/build-core-binary.sh)
desktop/src-tauri/resources/jardo-core/*
!desktop/src-tauri/resources/jardo-core/PLACEHOLDER

# PyInstaller work dir (frozen core is built, never committed)
build/
